# Anthropic API key for runtime (pay-per-use). NOT the Pro Max plan.
ANTHROPIC_API_KEY=

# Authenticated Arc RPC from the ARC CLI: run `arc-canteen rpc-url --export`
RPC=

# Temporary user address for backend-only testing before the wallet layer.
# Replaced by the connected wallet address passed from the frontend.
USER_ADDRESS=

# Test-only signing key for /api/confirm so the full send path can be validated.
# Never use a real key. Replaced by client-side user signing in production.
TEST_PRIVATE_KEY=

# Circle App Kit key for swaps, from console.circle.com. Read only in the test
# host, never in core. Replaced by the container's swap signer in production.
CIRCLE_KIT_KEY=

# Model: sonnet recommended, haiku if budget is tight
ANTHROPIC_MODEL=claude-sonnet-4-6

# Local backend port
PORT=8787
